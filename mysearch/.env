# =====================================================
# SearchEngine Bhoomy Search - Environment Configuration
# =====================================================
# Copy this file to .env and update with your settings

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mybhoomy_mysearch
DB_USER=mybhoomy_admin
DB_PASSWORD=mhQjj.%C-_LO_U4
DB_CONNECTION_LIMIT=200
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# =====================================================
# ELASTICSEARCH 8+ CONFIGURATION
# =====================================================
ELASTICSEARCH_URL=https://localhost:9200
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=bEvADDXp47tbSH32mPwB
ELASTICSEARCH_CA_CERT=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_CLOUD_ID=


# Connection Configuration
ELASTICSEARCH_MAX_RETRIES=3
ELASTICSEARCH_REQUEST_TIMEOUT=30000
ELASTICSEARCH_PING_TIMEOUT=3000
ELASTICSEARCH_KEEPALIVE=true
ELASTICSEARCH_MAX_SOCKETS=100

# Security Configuration
ELASTICSEARCH_SSL_VERIFY=false
ELASTICSEARCH_SSL_CA=
ELASTICSEARCH_SSL_CERT=
ELASTICSEARCH_SSL_KEY=

# =====================================================
# SEARCH INTERFACE CONFIGURATION
# =====================================================
SEARCH_PORT=8080
SEARCH_RESULTS_PER_PAGE=20
SEARCH_MAX_RESULTS=1000
SEARCH_HIGHLIGHT_LENGTH=200
SEARCH_CACHE_ENABLED=true
SEARCH_CACHE_TTL=300

# =====================================================
# REDIS CONFIGURATION (Optional - for caching)
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
REDIS_MAX_CONNECTIONS=10

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
JWT_SECRET=your-super-secret-jwt-key-change-this
SESSION_SECRET=your-super-secret-session-key-change-this
API_RATE_LIMIT=1000
API_RATE_WINDOW=900000

# =====================================================
# LOGGING CONFIGURATION
# =====================================================
LOG_LEVEL=info
LOG_FILE=logs/search.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# =====================================================
# PERFORMANCE CONFIGURATION
# =====================================================
NODE_ENV=production
MAX_MEMORY=2048
CLUSTER_WORKERS=auto

# =====================================================
# SEARCH ANALYTICS
# =====================================================
ANALYTICS_ENABLED=true
TRACK_SEARCH_QUERIES=true
TRACK_CLICK_THROUGH=true
ANALYTICS_RETENTION_DAYS=180

# =====================================================
# UI CONFIGURATION
# =====================================================
UI_THEME=light
UI_LANGUAGE=en
UI_RESULTS_LAYOUT=grid
UI_ENABLE_FILTERS=true
UI_ENABLE_SORTING=true
UI_ENABLE_SUGGESTIONS=true

# =====================================================
# API CONFIGURATION
# =====================================================
API_VERSION=v1
API_ENABLE_CORS=true
API_CORS_ORIGINS=*
API_ENABLE_COMPRESSION=true

# =====================================================
# MONITORING CONFIGURATION
# =====================================================
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
METRICS_PORT=8081

# =====================================================
# EXTERNAL API KEYS
# =====================================================
YOUTUBE_API_KEY=AIzaSyDN6QOd3VMnu9Wd6d-3DbowLTCWSzNTyQM
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# =====================================================
# SEARCH FEATURES
# =====================================================
ENABLE_AUTOCOMPLETE=true
ENABLE_SPELL_CHECK=true
ENABLE_FACETED_SEARCH=true
ENABLE_SEMANTIC_SEARCH=false
ENABLE_IMAGE_SEARCH=true
ENABLE_VIDEO_SEARCH=true
ENABLE_DOCUMENT_SEARCH=true
ENABLE_NEWS_SEARCH=true
ENABLE_SEARCH_ANALYTICS=true
ENABLE_SEARCH_SUGGESTIONS=true

# Advanced Search Features
ENABLE_FUZZY_SEARCH=true
ENABLE_PHRASE_SEARCH=true
ENABLE_WILDCARD_SEARCH=true
ENABLE_BOOST_FIELDS=true
ENABLE_HIGHLIGHT=true
ENABLE_AGGREGATIONS=true
ENABLE_DATE_FILTERS=true
ENABLE_CATEGORY_FILTERS=true
ENABLE_LANGUAGE_FILTERS=true
