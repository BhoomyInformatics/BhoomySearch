{
  "name": "bhoomy-search-engine",
  "version": "5.2.0",
  "description": "Modern Search Engine with React Frontend and Node.js Backend",
  "main": "app.js",
  "author": "Vijay R Dalvi",
  "license": "ISC",
  "keywords": [
    "search-engine",
    "elasticsearch",
    "web-search",
    "bhoomy",
    "react",
    "typescript",
    "search-interface"
  ],
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "dev:setup": "node start-dev.js",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend:dev\"",
    "build": "npm run frontend:build",
    "test": "node test/test-search.js",
    "test-api": "node test/test-api.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "health-check": "node utils/health-check.js"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "axios": "^1.8.3",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cheerio": "^1.1.2",
    "compression": "^1.7.4",
    "connect-mysql2": "^2.2.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "googleapis": "^149.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "md5": "^2.3.0",
    "mysql": "^2.18.1",
    "mysql2": "^3.11.3",
    "redis": "^4.7.0",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.12.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/searchengine-bhoomy.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/searchengine-bhoomy/issues"
  },
  "homepage": "https://github.com/your-username/searchengine-bhoomy#readme",
  "config": {
    "search": {
      "resultsPerPage": 20,
      "maxResults": 1000,
      "cacheTimeout": 300,
      "highlightLength": 200
    },
    "elasticsearch": {
      "maxRetries": 3,
      "requestTimeout": 30000,
      "pingTimeout": 3000
    },
    "redis": {
      "ttl": 3600,
      "maxConnections": 10
    }
  }
}
