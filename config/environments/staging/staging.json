{
  "app": {
    "env": "staging",
    "debug": false,
    "port": 8080,
    "maintenance": false,
    "cors": {
      "enabled": true,
      "origins": ["https://staging.bhoomy.com", "https://staging-admin.bhoomy.com"],
      "credentials": true
    }
  },
  "database": {
    "host": "staging-db.bhoomy.internal",
    "port": 3306,
    "name": "mybhoomy_staging",
    "user": "mybhoomy_staging",
    "connectionLimit": 15,
    "timeout": 30000,
    "ssl": true,
    "enableSlowQueryLogging": true,
    "slowQueryThreshold": 1000
  },
  "elasticsearch": {
    "url": "https://staging-elasticsearch.bhoomy.internal:9200",
    "requestTimeout": 15000,
    "pingTimeout": 2000,
    "maxRetries": 2,
    "ssl": {
      "verify": true,
      "rejectUnauthorized": true
    },
    "indices": {
      "main": "bhoomy_search_staging",
      "analytics": "search_analytics_staging",
      "images": "site_img_staging",
      "videos": "site_videos_staging",
      "documents": "site_doc_staging"
    }
  },
  "redis": {
    "enabled": true,
    "host": "staging-redis.bhoomy.internal",
    "port": 6379,
    "keyPrefix": "bhoomy:staging:",
    "maxConnections": 15,
    "defaultTTL": 1800,
    "searchCacheTTL": 300,
    "imageCacheTTL": 900,
    "videoCacheTTL": 1800
  },
  "security": {
    "rateLimiting": {
      "enabled": true,
      "maxRequests": 2000,
      "windowMs": 900000
    },
    "session": {
      "secure": true,
      "maxAge": 43200000,
      "sameSite": "strict"
    },
    "headers": {
      "contentSecurityPolicy": true,
      "strictTransportSecurity": true,
      "xFrameOptions": "DENY"
    }
  },
  "logging": {
    "level": "info",
    "enableConsole": true,
    "colorize": false,
    "enablePerformanceLogs": true,
    "enableSlowQueryLogs": true,
    "enableAccessLogs": true,
    "file": "logs/staging.log",
    "errorFile": "logs/staging-error.log",
    "maxSize": "50m",
    "maxFiles": 10,
    "enableStructuredLogs": true
  },
  "performance": {
    "enableCaching": true,
    "cacheDefaultTTL": 600,
    "enableCompression": true,
    "compressionLevel": 6,
    "enablePerformanceMonitoring": true,
    "monitoringInterval": 30000,
    "enableAlerts": true,
    "alertThresholds": {
      "responseTime": 2000,
      "memoryUsage": 75,
      "cpuUsage": 75,
      "errorRate": 3
    }
  },
  "search": {
    "resultsPerPage": 20,
    "maxResults": 1000,
    "enableSemanticSearch": true,
    "analyticsRetentionDays": 90,
    "enableSearchAnalytics": true,
    "trackSearchQueries": true,
    "trackClickThrough": true
  },
  "api": {
    "enableDocumentation": true,
    "enableRequestLogging": true,
    "enableValidation": true,
    "enableRateLimiting": true,
    "externalApis": {
      "youtube": {
        "enabled": true,
        "quotaLimit": 5000
      },
      "google": {
        "enabled": false
      }
    }
  },
  "ui": {
    "theme": "light",
    "enableFilters": true,
    "enableSorting": true,
    "enableKeyboardShortcuts": true,
    "enablePrefetching": true,
    "brandName": "Bhoomy Search (Staging)"
  },
  "monitoring": {
    "enabled": true,
    "healthCheckEnabled": true,
    "healthCheckInterval": 20000,
    "metricsEnabled": true,
    "alerting": {
      "enabled": true,
      "channels": ["console", "email"],
      "thresholds": {
        "responseTime": 3000,
        "errorRate": 3,
        "memoryUsage": 85,
        "diskUsage": 85
      }
    }
  }
}
