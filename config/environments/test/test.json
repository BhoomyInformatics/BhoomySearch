{
  "app": {
    "env": "test",
    "debug": false,
    "port": 3001,
    "maintenance": false,
    "cors": {
      "enabled": true,
      "origins": ["http://localhost:3001"],
      "credentials": false
    }
  },
  "database": {
    "host": "localhost",
    "port": 3306,
    "name": "mybhoomy_test",
    "user": "mybhoomy_test",
    "connectionLimit": 5,
    "timeout": 5000,
    "enableSlowQueryLogging": false,
    "slowQueryThreshold": 2000
  },
  "elasticsearch": {
    "url": "https://localhost:9200",
    "requestTimeout": 5000,
    "pingTimeout": 1000,
    "maxRetries": 1,
    "indices": {
      "main": "bhoomy_search_test",
      "analytics": "search_analytics_test",
      "images": "site_img_test",
      "videos": "site_videos_test",
      "documents": "site_doc_test"
    }
  },
  "redis": {
    "enabled": false,
    "keyPrefix": "bhoomy:test:",
    "defaultTTL": 60
  },
  "security": {
    "jwtSecret": "test-jwt-secret-32-characters-long-for-testing",
    "sessionSecret": "test-session-secret-32-chars-long-for-tests",
    "rateLimiting": {
      "enabled": false
    },
    "session": {
      "secure": false,
      "maxAge": 3600000
    },
    "headers": {
      "contentSecurityPolicy": false,
      "strictTransportSecurity": false
    }
  },
  "logging": {
    "level": "warn",
    "enableConsole": false,
    "colorize": false,
    "enablePerformanceLogs": false,
    "enableSlowQueryLogs": false,
    "enableAccessLogs": false,
    "file": "logs/test.log",
    "errorFile": "logs/test-error.log",
    "maxFiles": 2
  },
  "performance": {
    "enableCaching": false,
    "enableCompression": false,
    "enablePerformanceMonitoring": false,
    "enableAlerts": false
  },
  "search": {
    "resultsPerPage": 5,
    "maxResults": 50,
    "enableAutoComplete": false,
    "enableSpellCheck": false,
    "enableFacetedSearch": false,
    "enableSemanticSearch": false,
    "enableSearchAnalytics": false,
    "trackSearchQueries": false,
    "trackClickThrough": false,
    "analyticsRetentionDays": 7
  },
  "api": {
    "enableDocumentation": false,
    "enableRequestLogging": false,
    "enableValidation": true,
    "externalApis": {
      "youtube": {
        "enabled": false
      },
      "google": {
        "enabled": false
      }
    }
  },
  "ui": {
    "theme": "light",
    "enableFilters": false,
    "enableSorting": false,
    "enableKeyboardShortcuts": false,
    "brandName": "Bhoomy Search (Test)"
  },
  "monitoring": {
    "enabled": false,
    "healthCheckEnabled": true,
    "healthCheckInterval": 60000,
    "metricsEnabled": false,
    "alerting": {
      "enabled": false
    }
  }
}
