{
  "app": {
    "env": "development",
    "debug": true,
    "port": 3000,
    "maintenance": false,
    "cors": {
      "enabled": true,
      "origins": ["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000"],
      "credentials": true
    }
  },
  "database": {
    "host": "localhost",
    "port": 3306,
    "name": "mybhoomy_mysearch_dev",
    "connectionLimit": 10,
    "enableSlowQueryLogging": true,
    "slowQueryThreshold": 500
  },
  "elasticsearch": {
    "url": "https://localhost:9200",
    "ssl": {
      "verify": false,
      "rejectUnauthorized": false
    },
    "requestTimeout": 10000,
    "indices": {
      "main": "bhoomy_search_dev",
      "analytics": "search_analytics_dev",
      "images": "site_img_dev",
      "videos": "site_videos_dev",
      "documents": "site_doc_dev"
    }
  },
  "redis": {
    "enabled": false,
    "keyPrefix": "bhoomy:dev:",
    "defaultTTL": 300
  },
  "security": {
    "rateLimiting": {
      "enabled": false,
      "maxRequests": 10000
    },
    "session": {
      "secure": false,
      "maxAge": 86400000
    },
    "headers": {
      "contentSecurityPolicy": false,
      "strictTransportSecurity": false
    }
  },
  "logging": {
    "level": "debug",
    "enableConsole": true,
    "colorize": true,
    "enablePerformanceLogs": true,
    "enableSlowQueryLogs": true,
    "enableAccessLogs": true,
    "file": "logs/development.log",
    "errorFile": "logs/development-error.log"
  },
  "performance": {
    "enableCaching": false,
    "enableCompression": false,
    "enablePerformanceMonitoring": true,
    "monitoringInterval": 30000,
    "enableAlerts": false,
    "alertThresholds": {
      "responseTime": 5000,
      "memoryUsage": 95,
      "cpuUsage": 95,
      "errorRate": 10
    }
  },
  "search": {
    "resultsPerPage": 10,
    "maxResults": 100,
    "enableSemanticSearch": false,
    "analyticsRetentionDays": 30
  },
  "api": {
    "enableDocumentation": true,
    "enableRequestLogging": true,
    "enableValidation": true,
    "externalApis": {
      "youtube": {
        "enabled": true,
        "quotaLimit": 1000
      },
      "google": {
        "enabled": false
      }
    }
  },
  "ui": {
    "theme": "light",
    "enableFilters": true,
    "enableSorting": true,
    "enableKeyboardShortcuts": true,
    "brandName": "Bhoomy Search (Development)"
  },
  "monitoring": {
    "enabled": true,
    "healthCheckInterval": 10000,
    "metricsEnabled": true,
    "alerting": {
      "enabled": false,
      "channels": ["console"]
    }
  }
}
