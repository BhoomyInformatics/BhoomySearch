{
  "app": {
    "name": "Bhoomy Search Engine",
    "version": "1.0.0",
    "description": "Advanced Search Engine Platform",
    "port": 3000,
    "host": "localhost",
    "env": "development",
    "debug": false,
    "maintenance": false,
    "maxMemory": "2048",
    "clusterWorkers": "auto",
    "cors": {
      "enabled": true,
      "origins": "*",
      "credentials": false,
      "optionsSuccessStatus": 204
    }
  },
  "database": {
    "host": "localhost",
    "port": 3306,
    "name": "mybhoomy_mysearch",
    "user": "mybhoomy_admin",
    "password": "change-me-secure-password",
    "connectionLimit": 20,
    "acquireTimeout": 60000,
    "timeout": 60000,
    "charset": "utf8mb4",
    "timezone": "UTC",
    "ssl": false,
    "reconnect": true,
    "enablePerformanceOptimization": true,
    "enableQueryCaching": true,
    "enableSlowQueryLogging": true,
    "slowQueryThreshold": 1000,
    "cacheDefaultTTL": 300
  },
  "elasticsearch": {
    "url": "https://localhost:9200",
    "host": "localhost",
    "port": 9200,
    "username": "elastic",
    "password": "change-me-secure-password",
    "apiKey": "",
    "cloudId": "",
    "ssl": {
      "verify": false,
      "ca": "",
      "cert": "",
      "key": "",
      "rejectUnauthorized": false
    },
    "maxRetries": 3,
    "requestTimeout": 30000,
    "pingTimeout": 3000,
    "keepAlive": true,
    "maxSockets": 50,
    "indices": {
      "main": "bhoomy_search",
      "analytics": "search_analytics",
      "images": "site_img",
      "videos": "site_videos",
      "documents": "site_doc"
    }
  },
  "redis": {
    "enabled": false,
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0,
    "maxConnections": 10,
    "retryDelayOnFailover": 100,
    "enableOfflineQueue": false,
    "keyPrefix": "bhoomy:",
    "compression": true,
    "defaultTTL": 3600,
    "searchCacheTTL": 600,
    "imageCacheTTL": 1800,
    "videoCacheTTL": 3600
  },
  "security": {
    "jwtSecret": "change-me-jwt-secret-32-characters-long",
    "sessionSecret": "change-me-session-secret-32-chars-long",
    "rateLimiting": {
      "enabled": true,
      "maxRequests": 1000,
      "windowMs": 900000,
      "skipSuccessfulRequests": false,
      "skipFailedRequests": false,
      "standardHeaders": true,
      "legacyHeaders": false
    },
    "session": {
      "name": "bhoomySession",
      "resave": false,
      "saveUninitialized": false,
      "rolling": true,
      "maxAge": 86400000,
      "httpOnly": true,
      "secure": false,
      "sameSite": "lax"
    },
    "headers": {
      "contentSecurityPolicy": true,
      "crossOriginEmbedderPolicy": false,
      "crossOriginOpenerPolicy": false,
      "crossOriginResourcePolicy": false,
      "originAgentCluster": false,
      "referrerPolicy": "no-referrer",
      "strictTransportSecurity": true,
      "xContentTypeOptions": true,
      "xDnsPrefetchControl": true,
      "xFrameOptions": "DENY",
      "xPermittedCrossDomainPolicies": false,
      "xPoweredBy": false,
      "xXssProtection": true
    }
  },
  "logging": {
    "level": "info",
    "file": "logs/app.log",
    "errorFile": "logs/error.log",
    "maxSize": "10m",
    "maxFiles": 5,
    "enableConsole": true,
    "colorize": true,
    "format": "json",
    "timestamp": true,
    "enablePerformanceLogs": true,
    "enableSlowQueryLogs": true,
    "enableAccessLogs": true,
    "enableRotation": true,
    "rotationInterval": "daily",
    "enableStructuredLogs": true,
    "logRequestId": true,
    "logUserAgent": true
  },
  "performance": {
    "enableCaching": true,
    "cacheDefaultTTL": 300,
    "cacheMaxSize": 1000,
    "enableCompression": true,
    "compressionLevel": 6,
    "compressionThreshold": 1024,
    "enableDatabasePooling": true,
    "enableQueryOptimization": true,
    "enableIndexOptimization": true,
    "enableSearchCaching": true,
    "enableResultPrefetching": true,
    "enableQueryExpansion": true,
    "enablePerformanceMonitoring": true,
    "monitoringInterval": 60000,
    "enableAlerts": true,
    "alertThresholds": {
      "responseTime": 1000,
      "memoryUsage": 80,
      "cpuUsage": 80,
      "errorRate": 5
    }
  },
  "search": {
    "resultsPerPage": 20,
    "maxResults": 1000,
    "highlightLength": 200,
    "minQueryLength": 2,
    "maxQueryLength": 200,
    "enableAutoComplete": true,
    "enableSpellCheck": true,
    "enableFacetedSearch": true,
    "enableSemanticSearch": false,
    "enableImageSearch": true,
    "enableVideoSearch": true,
    "enableDocumentSearch": true,
    "enableNewsSearch": true,
    "enableFuzzySearch": true,
    "enablePhraseSearch": true,
    "enableWildcardSearch": true,
    "enableBoostFields": true,
    "enableHighlight": true,
    "enableAggregations": true,
    "enableDateFilters": true,
    "enableCategoryFilters": true,
    "enableLanguageFilters": true,
    "enableCountryFilters": true,
    "enableSearchAnalytics": true,
    "enableSearchSuggestions": true,
    "trackSearchQueries": true,
    "trackClickThrough": true,
    "analyticsRetentionDays": 180
  },
  "api": {
    "version": "v1",
    "prefix": "/api",
    "enableCors": true,
    "enableCompression": true,
    "enableRateLimiting": true,
    "enableValidation": true,
    "enableDocumentation": true,
    "enablePagination": true,
    "defaultPageSize": 20,
    "maxPageSize": 100,
    "enableApiKeys": false,
    "enableJwtAuth": true,
    "enableRequestLogging": true,
    "externalApis": {
      "youtube": {
        "enabled": true,
        "apiKey": "",
        "quotaLimit": 10000
      },
      "google": {
        "enabled": false,
        "apiKey": "",
        "searchEngineId": ""
      }
    }
  },
  "ui": {
    "theme": "light",
    "language": "en",
    "resultsLayout": "list",
    "enableFilters": true,
    "enableSorting": true,
    "enableSuggestions": true,
    "enableInfiniteScroll": false,
    "enableKeyboardShortcuts": true,
    "lazyLoadImages": true,
    "enableVirtualization": false,
    "enablePrefetching": true,
    "brandName": "Bhoomy Search",
    "brandLogo": "",
    "customCSS": "",
    "customJS": ""
  },
  "monitoring": {
    "enabled": true,
    "healthCheckEnabled": true,
    "healthCheckInterval": 30000,
    "healthCheckPath": "/health",
    "metricsEnabled": true,
    "metricsPort": 9090,
    "metricsPath": "/metrics",
    "alerting": {
      "enabled": true,
      "channels": ["console"],
      "thresholds": {
        "responseTime": 5000,
        "errorRate": 5,
        "memoryUsage": 90,
        "diskUsage": 90
      }
    }
  }
}
