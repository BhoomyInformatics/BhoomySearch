{
  "name": "bhoomy-crawler",
  "version": "5.2.0",
  "description": "Advanced web crawler for SearchEngine Bhoomy with modular architecture",
  "main": "crawl.js",
  "author": "Vijay R Dalvi",
  "license": "ISC",
  "keywords": [
    "web-crawler",
    "search-engine",
    "elasticsearch",
    "content-indexing",
    "bhoomy"
  ],
  "scripts": {
    "start": "node index.js",
    "server": "node server.js",
    "test": "NODE_ENV=test node index.js",
    "test-db": "node test/test-database.js",
    "test-indexer": "node test/test-indexer.js",
    "migrate-db": "mysql -u mybhoomy_bhoomy -p mybhoomy_mysearch < ../database-migration.sql",
    "create-schema": "mysql -u mybhoomy_bhoomy -p mybhoomy_mysearch < ../database-schema-complete.sql",
    "dev": "NODE_ENV=development node index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "health-check": "node utils/health-check.js",
    "cleanup": "node cleanup.js",
    "cleanup-logs": "node -e \"require('./utils/log-cleanup').autoCleanup()\"",
    "crawler-safe": "NODE_ENV=production LOG_LEVEL=warn node crawl.js",
    "production": "NODE_ENV=production node index.js",
    "high-performance": "NODE_ENV=production MAX_CONNECTIONS=300 OPTIMIZE_FOR_CAPACITY=true node index.js",
    "check-system": "node check-system-status.js",
    "monitor": "node -e \"setInterval(() => { const usage = process.memoryUsage(); console.log('Memory:', Math.round(usage.heapUsed/1024/1024), 'MB'); }, 5000);\"",
    "multi-session": "node multi-session-manager.js start",
    "multi-stop": "node multi-session-manager.js stop",
    "multi-status": "node multi-session-manager.js status",
    "crawl-com": "MULTI_SESSION_ENABLED=true SESSION_ID=bhoomy_com node bhoomy_com.js",
    "crawl-in": "MULTI_SESSION_ENABLED=true SESSION_ID=bhoomy_in node bhoomy_in.js",
    "crawl-org": "MULTI_SESSION_ENABLED=true SESSION_ID=bhoomy_org node bhoomy_org.js",
    "crawl-store": "MULTI_SESSION_ENABLED=true SESSION_ID=bhoomy_store node bhoomy_store.js",
    "crawl-news": "MULTI_SESSION_ENABLED=true SESSION_ID=news_site node news_site.js",
    "crawl-special": "MULTI_SESSION_ENABLED=true SESSION_ID=specialsite node specialsite.js",
    "check-database": "node check-database-stats.js",
    "unlock-sites": "node unlocked.js"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "async-retry": "^1.3.3",
    "axios": "^1.8.3",
    "bcrypt": "^5.1.1",
    "bhoomy-crawler": "file:",
    "body-parser": "^1.20.2",
    "cheerio": "^1.0.0-rc.12",
    "content-type": "^1.0.5",
    "cors": "^2.8.5",
    "crawler": "^1.5.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "https-proxy-agent": "^7.0.6",
    "joi": "^17.13.3",
    "jquery": "^3.7.1",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "md5": "^2.3.0",
    "mime-types": "^2.1.35",
    "mysql2": "^3.14.4",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "node-schedule": "^2.1.1",
    "officeparser": "^5.1.1",
    "p-limit": "^6.2.0",
    "pdf-parse": "^1.1.1",
    "pptxgenjs": "^3.12.0",
    "proxy-agent": "^6.4.0",
    "robots-parser": "^3.0.1",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "user-agents": "^1.1.490",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/searchengine-bhoomy.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/searchengine-bhoomy/issues"
  },
  "homepage": "https://github.com/your-username/searchengine-bhoomy#readme",
  "config": {
    "crawler": {
      "maxConcurrency": 10,
      "defaultDelay": 1000,
      "maxRetries": 3,
      "timeout": 30000
    },
    "database": {
      "connectionLimit": 20,
      "acquireTimeout": 60000,
      "timeout": 60000
    },
    "elasticsearch": {
      "maxRetries": 3,
      "requestTimeout": 30000,
      "pingTimeout": 3000
    }
  }
}
