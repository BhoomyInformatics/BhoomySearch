# =====================================================
# SearchEngine Bhoomy Crawler - Environment Configuration
# =====================================================
# Copy this file to .env and update with your settings

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
DB_HOST=localhost
DB_PORT=3306
ELASTICSEARCH_INDEX=bhoomy_search
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=MtuWUQonC5bUkcGyfPwh
DB_CONNECTION_LIMIT=20
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# =====================================================
# ELASTICSEARCH CONFIGURATION
# =====================================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=bhoomy_search
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_MAX_RETRIES=3
ELASTICSEARCH_REQUEST_TIMEOUT=30000
ELASTICSEARCH_PING_TIMEOUT=3000

# =====================================================
# CRAWLER CONFIGURATION - HIGH-PERFORMANCE SETTINGS
# =====================================================

# Basic Crawler Settings
CRAWLER_PORT=3000
CRAWLER_USER_AGENT=SearchEngine Bhoomy Bot 1.0
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_MAX_DEPTH=5
CRAWLER_MAX_PAGES=1000

# Performance Settings (Optimized for Monster Server)
CRAWLER_MAX_CONCURRENCY=200            # High concurrency for 48-core server
CRAWLER_MAX_GLOBAL_CONNECTIONS=600     # Total connections across all domains
CRAWLER_MAX_CONNECTIONS_PER_DOMAIN=5   # RESPECTFUL per-domain limit (reduced from 15)
CRAWLER_CONCURRENT_LIMIT=300           # Processing limit
CRAWLER_BATCH_SIZE=100                 # Large batches for efficiency

# Timing Settings (Balanced for speed + politeness)
CRAWLER_DEFAULT_DELAY=100              # Minimal delay between requests
CRAWLER_MIN_DELAY=50                   # Fastest possible delay
CRAWLER_MAX_DELAY=200                  # Maximum delay for slow sites
CRAWLER_ADAPTIVE_DELAY=true            # Use adaptive delays based on site response

# Timeout & Retry Settings (Improved resilience)
CRAWLER_TIMEOUT=45000                  # 45 seconds for slow government sites
CRAWLER_BASE_TIMEOUT=30000             # Base timeout for normal sites
CRAWLER_SLOW_SITE_TIMEOUT=60000        # Extended timeout for government/enterprise sites
CRAWLER_FAST_SITE_TIMEOUT=15000        # Quick timeout for commercial sites
CRAWLER_MAX_RETRIES=3                  # Retry attempts
CRAWLER_RETRY_DELAY=3000               # Delay between retries

# Network Resilience
CRAWLER_DNS_TIMEOUT=10000              # DNS resolution timeout
CRAWLER_CONNECT_TIMEOUT=15000          # Connection timeout
CRAWLER_RESPONSE_TIMEOUT=45000         # Response timeout
CRAWLER_MAX_REDIRECTS=5                # Maximum redirects to follow

# Content Processing Limits
CRAWLER_MAX_CONTENT_SIZE=2MB           # Maximum page size to process
CRAWLER_MAX_IMAGE_SIZE=1MB             # Maximum image size to download
CRAWLER_MAX_LINKS_PER_PAGE=50          # Maximum links to extract per page

# System Resource Protection
CRAWLER_MEMORY_THRESHOLD=0.75          # Memory usage threshold (75%)
CRAWLER_CPU_THRESHOLD=0.8              # CPU usage threshold (80%)
CRAWLER_EMERGENCY_STOP_ON_EMFILE=true  # Stop on file descriptor limit

# Queue Management
CRAWLER_QUEUE_SIZE=5000                # Maximum queue size
CRAWLER_QUEUE_TIMEOUT=45000            # Queue timeout
CRAWLER_BACKPRESSURE_THRESHOLD=0.8     # Backpressure activation threshold

# Logging & Monitoring
CRAWLER_LOG_LEVEL=info                 # Logging level (debug/info/warn/error)
CRAWLER_ENABLE_DETAILED_LOGGING=false  # Enable detailed request logging
CRAWLER_STATS_INTERVAL=30000           # Statistics reporting interval

# =====================================================
# ENVIRONMENT SPECIFIC OVERRIDES
# =====================================================

# Set NODE_ENV to automatically optimize settings
# NODE_ENV=production                   # Enables production optimizations
# NODE_ENV=development                  # Enables debug logging
# OPTIMIZE_FOR_CAPACITY=true           # Force high-capacity optimizations

# =====================================================
# POLITENESS & ETHICS SETTINGS
# =====================================================

CRAWLER_RESPECT_RATE_LIMITS=true       # Respect X-RateLimit headers
CRAWLER_HONOR_RETRY_AFTER=true         # Honor Retry-After headers  
CRAWLER_USER_AGENT_ROTATION=true       # Rotate user agents
CRAWLER_DOMAIN_COOLDOWN=300000         # 5-minute cooldown for problematic domains
CRAWLER_MAX_CONSECUTIVE_FAILURES=5     # Stop after 5 consecutive failures per domain

# =====================================================
# SECURITY SETTINGS
# =====================================================

CRAWLER_REJECT_UNAUTHORIZED=false      # Accept self-signed certificates
CRAWLER_STRICT_SSL=false               # Disable strict SSL checking
CRAWLER_ENABLE_PROXY_ROTATION=false    # Enable proxy rotation (set to true if using proxies)
CRAWLER_PROXY_LIST=                    # Comma-separated proxy list

# =====================================================
# CONTENT TYPE HANDLING
# =====================================================

CRAWLER_PROCESS_HTML=true              # Process HTML content
CRAWLER_PROCESS_JSON=true              # Process JSON APIs
CRAWLER_PROCESS_PDF=true               # Process PDF documents
CRAWLER_PROCESS_IMAGES=true            # Process images
CRAWLER_PROCESS_DOCUMENTS=true         # Process other documents

# =====================================================
# STORAGE SETTINGS
# =====================================================

CRAWLER_ENABLE_DATABASE_STORAGE=true   # Store results in database
CRAWLER_ENABLE_ELASTICSEARCH=true      # Index in Elasticsearch
CRAWLER_ENABLE_FILE_CACHE=false        # Enable file-based caching
CRAWLER_CACHE_DIRECTORY=./temp         # Cache directory path

# =====================================================
# ADVANCED PERFORMANCE TUNING
# =====================================================

# Connection Pool Settings
CRAWLER_POOL_MAX_SOCKETS=300           # Maximum sockets per agent
CRAWLER_POOL_MAX_FREE_SOCKETS=50       # Maximum free sockets
CRAWLER_POOL_KEEP_ALIVE=true           # Enable keep-alive connections
CRAWLER_POOL_KEEP_ALIVE_MSECS=30000    # Keep-alive timeout

# Advanced Queue Settings  
CRAWLER_QUEUE_PRIORITY_ENABLED=true    # Enable priority queue
CRAWLER_QUEUE_DEDUPLICATION=true       # Enable URL deduplication
CRAWLER_QUEUE_PERSISTENCE=false        # Persist queue to disk

# Monitoring & Alerting
CRAWLER_ENABLE_METRICS=true            # Enable performance metrics
CRAWLER_METRICS_PORT=9090              # Metrics server port
CRAWLER_ENABLE_HEALTH_CHECKS=true      # Enable health check endpoint

# =====================================================
# EXAMPLE URLS FOR TESTING
# =====================================================

# TEST_URLS=https://example.com,https://test.com
# PRIORITY_DOMAINS=gov.in,nic.in,maharashtra.gov.in

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
JWT_SECRET=your-super-secret-jwt-key-change-this
SESSION_SECRET=your-super-secret-session-key-change-this
API_RATE_LIMIT=100
API_RATE_WINDOW=900000

# =====================================================
# LOGGING CONFIGURATION
# =====================================================
LOG_LEVEL=info
LOG_FILE=logs/crawler.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# =====================================================
# PERFORMANCE CONFIGURATION
# =====================================================
NODE_ENV=production
MAX_MEMORY=2048
CLUSTER_WORKERS=auto

# =====================================================
# PROXY CONFIGURATION (Optional)
# =====================================================
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# =====================================================
# MONITORING CONFIGURATION
# =====================================================
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
METRICS_PORT=3001

# =====================================================
# CONTENT PROCESSING
# =====================================================
CONTENT_MAX_SIZE=10485760
IMAGE_PROCESSING_ENABLED=true
VIDEO_PROCESSING_ENABLED=true
DOCUMENT_PROCESSING_ENABLED=true
PDF_PROCESSING_ENABLED=true

# =====================================================
# DUPLICATE DETECTION
# =====================================================
DUPLICATE_DETECTION_ENABLED=true
CONTENT_HASH_ALGORITHM=sha256
URL_HASH_ALGORITHM=sha256

# =====================================================
# CLEANUP CONFIGURATION
# =====================================================
CLEANUP_INTERVAL=86400000
DUPLICATE_RETENTION_DAYS=30
LOG_RETENTION_DAYS=7 